{
  "manifest_version": 3,
  "name": "WebBluetooth Extension",
  "version": "1.0",
  "description": "Enables WebBluetooth functionality for Firefox on Linux.",
  "permissions": [
    "nativeMessaging",
    "storage",
    "webNavigation"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "webbluetooth-firefox-extension@example.com"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["polyfill.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}