{
  "manifest_version": 3,
  "name": "WebBluetooth for Firefox",
  "version": "1.0",
  "description": "Enables the Web Bluetooth API in Firefox on Linux, bridging the browser to Bluetooth hardware via a native messaging host.",
  "permissions": [
    "nativeMessaging",
    "storage",
    "webNavigation"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "webbluetooth@rfvx.github.io",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "polyfill.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
